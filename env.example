import React from 'react'

const fmt = v => {
  if (!v && v !== 0) return '–'
  if (v >= 1e6) return (v / 1e6).toFixed(1) + 'M'
  if (v >= 1e3) return Math.round(v / 1e3) + 'K'
  return v
}

export function KpiGrid({ metrics }) {
  const top = metrics[0]
  const fastest = [...metrics].sort((a, b) => (b.growth_12m_pct || 0) - (a.growth_12m_pct || 0))[0]
  const totalYTD = metrics.reduce((s, m) => s + (m.apr_ytd_searches || 0), 0)
  const growing = metrics.filter(m => m.growth_12m_pct > 0).length

  const cards = [
    { label: 'Marcas analizadas', value: metrics.length, sub: `${growing} con crecimiento positivo` },
    { label: 'Búsquedas Abr. YTD', value: fmt(totalYTD), sub: 'suma de todas las marcas' },
    { label: 'Líder en búsquedas', value: top?.brands?.name || '–', sub: `${fmt(top?.apr_ytd_searches)} búsquedas` },
    { label: 'Mayor crecimiento', value: fastest?.brands?.name || '–', sub: `+${Math.round((fastest?.growth_12m_pct || 0) * 100)}% vs año anterior` },
  ]

  return (
    <div style={{
      display: 'grid',
      gridTemplateColumns: 'repeat(4, 1fr)',
      gap: '10px',
      marginBottom: '20px',
    }}>
      {cards.map((c, i) => (
        <div key={i} style={{
          background: 'var(--surface)',
          border: '0.5px solid var(--border)',
          borderRadius: 'var(--radius)',
          padding: '18px 20px',
          animation: `fadeUp 0.4s ease ${i * 0.08}s both`,
        }}>
          <div style={{ fontSize: '10px', letterSpacing: '0.1em', textTransform: 'uppercase', color: 'var(--text3)', marginBottom: '10px' }}>
            {c.label}
          </div>
          <div style={{ fontFamily: 'Syne, sans-serif', fontSize: '22px', fontWeight: 600, color: 'var(--text)', lineHeight: 1 }}>
            {c.value}
          </div>
          <div style={{ fontSize: '11px', color: 'var(--text2)', marginTop: '6px' }}>{c.sub}</div>
        </div>
      ))}
    </div>
  )
}
